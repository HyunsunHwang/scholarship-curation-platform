{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "manifestVersion", "universitySlug", "sources"],
  "properties": {
    "schemaVersion": { "const": "notice-source-manifest-v1" },
    "manifestVersion": { "type": "string", "minLength": 1 },
    "universitySlug": { "type": "string", "enum": ["ewha", "cau", "korea", "khu", "hanyang", "hongik", "yonsei", "skku", "uos"] },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["sourceId", "universitySlug", "universityId", "collegeId", "departmentId", "orgUnitId", "collegeName", "departmentName", "sourceLevel", "sourceName", "listUrl", "baseUrl", "listItemSelector", "linkSelector", "titleSelector", "dateSelector", "detailContentSelector", "detailDateSelector", "noticeUrlPattern", "keywords", "adapter", "enabled"],
        "properties": {
          "sourceId": { "type": "string", "minLength": 1 },
          "universitySlug": { "type": "string", "minLength": 1 },
          "universityId": { "type": "string" }, "collegeId": { "type": "string" }, "departmentId": { "type": "string" }, "orgUnitId": { "type": "string" },
          "collegeName": { "type": "string" }, "departmentName": { "type": "string" },
          "sourceLevel": { "type": "string", "enum": ["university", "college", "department", "division"] },
          "sourceName": { "type": "string", "minLength": 1 }, "listUrl": { "type": "string", "minLength": 1 }, "baseUrl": { "type": "string" },
          "listItemSelector": { "type": "string" }, "linkSelector": { "type": "string" }, "titleSelector": { "type": "string" }, "dateSelector": { "type": "string" },
          "detailContentSelector": { "type": "string" }, "detailDateSelector": { "type": "string" }, "noticeUrlPattern": { "type": "string" },
          "contentMode": { "type": "string", "enum": ["", "inline_sections"] },
          "detailFetchRequired": { "type": "boolean" }, "detailContentAlreadyAvailable": { "type": "boolean" },
          "sectionTitleSelector": { "type": "string" }, "sectionBodyBoundary": { "type": "string", "enum": ["", "next_heading"] }, "sectionPublishedDateSelector": { "type": "string" },
          "undatedCandidatePolicy": { "type": "string", "enum": ["manual_review", "reject", "allow_explicitly"] },
          "keywords": { "type": "array", "items": { "type": "string" } },
          "adapter": { "type": "string" },
          "adapterConfig": {
            "type": "object",
            "additionalProperties": false,
            "required": ["apiAccept", "jsonContentTypePolicy", "requiredListPath"],
            "properties": {
              "apiAccept": { "type": "string", "minLength": 1, "pattern": "^[^\\r\\n]+$" },
              "jsonContentTypePolicy": { "type": "string", "enum": ["strict", "body-json"] },
              "requiredListPath": {
                "type": "string",
                "pattern": "^[A-Za-z_$][A-Za-z0-9_$]*(?:\\.[A-Za-z_$][A-Za-z0-9_$]*)*$"
              },
              "requestUrlTemplate": { "type": "string", "minLength": 1 },
              "detailUrlTemplate": { "type": "string", "minLength": 1 },
              "totalPagesPath": {
                "type": "string",
                "pattern": "^[A-Za-z_$][A-Za-z0-9_$]*(?:\\.[A-Za-z_$][A-Za-z0-9_$]*)*$"
              },
              "fieldMap": {
                "type": "object",
                "additionalProperties": false,
                "required": ["id", "title", "date", "content"],
                "properties": {
                  "id": { "type": "string", "pattern": "^[A-Za-z_$][A-Za-z0-9_$]*(?:\\.[A-Za-z_$][A-Za-z0-9_$]*)*$" },
                  "title": { "type": "string", "pattern": "^[A-Za-z_$][A-Za-z0-9_$]*(?:\\.[A-Za-z_$][A-Za-z0-9_$]*)*$" },
                  "date": { "type": "string", "pattern": "^[A-Za-z_$][A-Za-z0-9_$]*(?:\\.[A-Za-z_$][A-Za-z0-9_$]*)*$" },
                  "content": { "type": "string", "pattern": "^[A-Za-z_$][A-Za-z0-9_$]*(?:\\.[A-Za-z_$][A-Za-z0-9_$]*)*$" },
                  "isPinned": { "type": "string", "pattern": "^[A-Za-z_$][A-Za-z0-9_$]*(?:\\.[A-Za-z_$][A-Za-z0-9_$]*)*$" }
                }
              }
            }
          },
          "enabled": { "type": "boolean" }
        }
      }
    }
  }
}
