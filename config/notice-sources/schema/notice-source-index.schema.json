{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object", "additionalProperties": false,
  "required": ["schemaVersion", "manifestVersion", "groups"],
  "properties": {
    "schemaVersion": { "const": "notice-source-index-v1" },
    "manifestVersion": { "type": "string", "minLength": 1 },
    "groups": { "type": "array", "items": { "type": "object", "additionalProperties": false, "required": ["universitySlug", "path"], "properties": { "universitySlug": { "type": "string" }, "path": { "type": "string", "minLength": 1 } } } }
  }
}
