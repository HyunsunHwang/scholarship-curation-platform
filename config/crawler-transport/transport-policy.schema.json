{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "registryVersion",
    "userAgentProfiles",
    "defaults",
    "profiles",
    "bindings"
  ],
  "properties": {
    "schemaVersion": { "const": "crawler-transport-policy-v1" },
    "registryVersion": { "type": "string", "minLength": 1 },
    "userAgentProfiles": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "string",
        "minLength": 1,
        "maxLength": 512
      }
    },
    "defaults": { "$ref": "#/$defs/completePolicy" },
    "profiles": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/policyOverride" }
    },
    "bindings": {
      "type": "array",
      "items": { "$ref": "#/$defs/binding" }
    }
  },
  "$defs": {
    "retry": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "count": { "type": "integer", "minimum": 0, "maximum": 3 },
        "baseDelayMs": { "type": "integer", "minimum": 0, "maximum": 30000 },
        "maximumDelayMs": { "type": "integer", "minimum": 0, "maximum": 30000 },
        "jitterRatio": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "redirect": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "maximumHops": { "type": "integer", "minimum": 0, "maximum": 10 },
        "allowCrossHost": { "type": "boolean" },
        "allowHttpsToHttpDowngrade": { "type": "boolean" }
      }
    },
    "policyOverride": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "protocolMode": {
          "type": "string",
          "enum": ["strict", "preserve", "preserve-http"]
        },
        "dnsFamily": {
          "type": "string",
          "enum": ["auto", "ipv4", "ipv6"]
        },
        "tlsMode": {
          "type": "string",
          "enum": ["strict", "system-ca", "insecure-exact-host"]
        },
        "userAgentProfile": { "type": "string", "minLength": 1 },
        "timeoutMs": { "type": "integer", "minimum": 1, "maximum": 120000 },
        "maximumResponseBytes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 52428800
        },
        "retry": { "$ref": "#/$defs/retry" },
        "redirect": { "$ref": "#/$defs/redirect" }
      }
    },
    "completePolicy": {
      "allOf": [
        { "$ref": "#/$defs/policyOverride" },
        {
          "type": "object",
          "required": [
            "protocolMode",
            "dnsFamily",
            "tlsMode",
            "userAgentProfile",
            "timeoutMs",
            "maximumResponseBytes",
            "retry",
            "redirect"
          ],
          "properties": {
            "protocolMode": true,
            "dnsFamily": true,
            "tlsMode": true,
            "userAgentProfile": true,
            "timeoutMs": true,
            "maximumResponseBytes": true,
            "retry": {
              "allOf": [
                { "$ref": "#/$defs/retry" },
                {
                  "type": "object",
                  "required": [
                    "count",
                    "baseDelayMs",
                    "maximumDelayMs",
                    "jitterRatio"
                  ],
                  "properties": {
                    "count": true,
                    "baseDelayMs": true,
                    "maximumDelayMs": true,
                    "jitterRatio": true
                  }
                }
              ]
            },
            "redirect": {
              "allOf": [
                { "$ref": "#/$defs/redirect" },
                {
                  "type": "object",
                  "required": [
                    "maximumHops",
                    "allowCrossHost",
                    "allowHttpsToHttpDowngrade"
                  ],
                  "properties": {
                    "maximumHops": true,
                    "allowCrossHost": true,
                    "allowHttpsToHttpDowngrade": true
                  }
                }
              ]
            }
          }
        }
      ]
    },
    "binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bindingId", "priority"],
      "properties": {
        "bindingId": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "priority": { "type": "integer", "minimum": 0, "maximum": 1000 },
        "sourceIds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "universitySlugs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "hosts": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "allowedHosts": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "allowedHttpHosts": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "profile": { "type": "string", "minLength": 1 },
        "policy": { "$ref": "#/$defs/policyOverride" },
        "reason": { "type": "string", "minLength": 1 },
        "evidenceCommit": {
          "type": "string",
          "pattern": "^[a-f0-9]{7,40}$"
        },
        "createdAt": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "expiresAt": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        }
      },
      "anyOf": [
        { "required": ["sourceIds"], "properties": { "sourceIds": true } },
        {
          "required": ["universitySlugs"],
          "properties": { "universitySlugs": true }
        },
        { "required": ["hosts"], "properties": { "hosts": true } }
      ]
    }
  }
}
