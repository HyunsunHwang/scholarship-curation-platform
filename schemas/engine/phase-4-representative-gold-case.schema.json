{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scholarship-curation-platform.local/schemas/engine/phase-4-representative-gold-case.schema.json",
  "title": "Engine Phase 4 representative public candidate-gold case",
  "type": "object",
  "additionalProperties": false,
  "required": ["case_id", "source_key", "source_level", "source_type", "public_url", "notice_identity", "public_title", "public_posted_date", "document_kind_gold", "input_format", "parser_quality", "selection_stratum", "selection_reason", "source_status", "source_capture_hash", "source_capture_scope", "annotator_policy_version", "annotation_status", "adjudication_status", "gold_fields", "gold_review_required", "gold_review_reason_codes", "gold_evidence", "partial_gold", "relation_group_ids", "evaluation_input"],
  "properties": {
    "case_id": { "type": "string", "pattern": "^p4c_[a-z0-9_]+$" },
    "source_key": { "type": "string", "minLength": 1 },
    "source_level": { "enum": ["university", "college", "department", "graduate_school", "student_support", "external_foundation"] },
    "source_type": { "type": "string", "minLength": 1 },
    "public_url": { "type": "string", "format": "uri", "pattern": "^https?://" },
    "notice_identity": { "type": "string", "pattern": "^[a-f0-9]{24}$" },
    "public_title": { "type": "string", "minLength": 1 },
    "public_posted_date": { "type": "string", "format": "date" },
    "document_kind_gold": { "enum": ["recruitment_notice", "result_announcement", "correction_notice", "information_session", "general_guidance", "unknown"] },
    "input_format": { "enum": ["html", "pdf", "table", "hwp", "hwpx", "image"] },
    "parser_quality": { "enum": ["text_sufficient", "partial_text", "tool_unavailable", "ocr_not_evaluated"] },
    "selection_stratum": { "type": "string", "minLength": 1 },
    "selection_reason": { "type": "string", "minLength": 1 },
    "source_status": { "enum": ["available_at_selection", "available_list_identity_only", "unavailable_after_selection"] },
    "source_capture_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "source_capture_scope": { "const": "minimal_public_evidence_snapshot" },
    "annotator_policy_version": { "const": "engine-phase-4-representative-gold-policy/v1" },
    "annotation_status": { "const": "candidate_gold" },
    "adjudication_status": { "const": "pending_independent_review" },
    "gold_fields": { "type": "object", "minProperties": 14, "additionalProperties": { "$ref": "#/$defs/fieldAnnotation" } },
    "gold_review_required": { "type": "boolean" },
    "gold_review_reason_codes": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "gold_evidence": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/evidence" } },
    "partial_gold": { "type": "array", "items": { "$ref": "#/$defs/partialGold" } },
    "relation_group_ids": { "type": "array", "uniqueItems": true, "items": { "type": "string", "pattern": "^rg_" } },
    "evaluation_input": { "type": "object", "required": ["sourceNotice", "sourceDocuments"], "properties": { "sourceNotice": { "type": "object" }, "sourceDocuments": { "type": "array" } }, "additionalProperties": false }
  },
  "$defs": {
    "fieldAnnotation": {
      "type": "object", "additionalProperties": false,
      "required": ["value_status", "raw_value", "normalized_value", "evidence_refs", "annotation_reason", "partial_match_policy"],
      "properties": {
        "value_status": { "enum": ["present", "not_found", "unknown", "not_applicable", "ambiguous", "conflicting"] },
        "raw_value": {}, "normalized_value": {},
        "evidence_refs": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "annotation_reason": { "type": "string", "minLength": 1 },
        "partial_match_policy": { "anyOf": [{ "type": "null" }, { "type": "object", "required": ["policy", "threshold"], "properties": { "policy": { "enum": ["set_precision_recall/v1", "range_boundary_and_bounded_overlap/v1", "condition_set_and_boolean_structure/v1"] }, "threshold": { "type": "null" } }, "additionalProperties": false }] }
      }
    },
    "evidence": {
      "type": "object", "additionalProperties": false,
      "required": ["evidence_id", "source_type", "excerpt", "content_hash", "document_revision_hash", "locator", "annotation_reason"],
      "properties": {
        "evidence_id": { "type": "string", "minLength": 1 },
        "source_type": { "enum": ["html_text", "pdf_text", "pdf_table_cell", "attachment_metadata"] },
        "excerpt": { "type": "string", "minLength": 1, "maxLength": 500 },
        "content_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "document_revision_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "locator": { "type": "object", "minProperties": 1 },
        "annotation_reason": { "type": "string", "minLength": 1 }
      }
    },
    "partialGold": {
      "type": "object", "additionalProperties": false, "required": ["field", "policy", "threshold"],
      "properties": { "field": { "type": "string", "minLength": 1 }, "policy": { "enum": ["set_precision_recall/v1", "range_boundary_and_bounded_overlap/v1", "condition_set_and_boolean_structure/v1"] }, "threshold": { "type": "null" } }
    }
  }
}
